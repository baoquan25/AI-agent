# ─── Daytona API ────────────────────────────────────────────────────────
DAYTONA_API_KEY=your_daytona_api_key
DAYTONA_API_URL=http://localhost:3000/api

# ─── LLM ────────────────────────────────────────────────────────────────
OPENAI_KEY=your_openai_api_key

# ─── Service URLs ────────────────────────────────────────────────────────
SANDBOX_API_URL=http://localhost:8000
AGENT_API_URL=http://localhost:8001

# ─── Agent settings ─────────────────────────────────────────────────────
LLM_MODEL=openai/gpt-5-nano-2025-08-07
REASONING_EFFORT=low
SNAPSHOT_NAME=daytonaio/sandbox:0.5.0-slim
AUTO_STOP_INTERVAL=7200
LANGUAGE=python

# ─── Sandbox settings ────────────────────────────────────────────────────
FILE_CACHE_MAX_SIZE=1000
FILE_CACHE_TTL_SECONDS=300
